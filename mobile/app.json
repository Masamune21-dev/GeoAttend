{
  "expo": {
    "name": "GeoAttend",
    "slug": "geoattend",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "net.kusumavision.geoattend",
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera dipakai untuk foto bukti absensi.",
        "NSLocationWhenInUseUsageDescription": "Lokasi dipakai untuk validasi area absensi.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Lokasi background dipakai untuk pemantauan posisi selama jam kerja (setelah absen masuk hingga absen pulang)."
      }
    },
    "android": {
      "package": "net.kusumavision.geoattend",
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Kamera dipakai untuk foto bukti absensi."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lokasi dipakai untuk validasi area absensi.",
          "locationAlwaysAndWhenInUsePermission": "Lokasi background dipakai untuk pemantauan posisi selama jam kerja.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Galeri dipakai untuk memilih foto profil dan sampul."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2c3a7f73-74bd-47dd-94fb-2fe88e79cdd7"
      }
    },
    "owner": "masamune21s-team"
  }
}
