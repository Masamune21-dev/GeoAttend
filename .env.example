# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://geoattend:geoattend_dev_password@localhost:5432/geoattend

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate dengan: openssl rand -base64 32
BETTER_AUTH_SECRET=ganti-dengan-secret-minimal-32-karakter
# URL publik aplikasi (mis. https://absensi.contoh.com bila di balik reverse proxy/tunnel)
BETTER_AUTH_URL=http://localhost:3000
# Origin lain yang diizinkan login (dipisah koma), mis. domain tunnel + localhost
# BETTER_AUTH_TRUSTED_ORIGINS=https://absensi.contoh.com,http://localhost:3000
SESSION_EXPIRY_DAYS=7

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_NAME=GeoAttend
NEXT_PUBLIC_DEFAULT_LAT=-6.2087634
NEXT_PUBLIC_DEFAULT_LNG=106.8455990
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
DEFAULT_GEOFENCE_RADIUS_M=100

# ===========================================
# DEVELOPMENT
# ===========================================
NODE_ENV=development
LOG_LEVEL=info
